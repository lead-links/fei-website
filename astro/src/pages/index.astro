---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PROGRAMS, ICONS } from '../data/programs';
import { ORG, websiteSchema, faqSchema } from '../data/schema';
import CtaBlock from '../components/CtaBlock.astro';

// Official home page ("/"). Content promoted from the former A/B variant B
// (git history holds the previous version).
const chev = (dir: 'd' | 'u') =>
  `<svg class="acc-ico__${dir}" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="${dir === 'd' ? 'M6 9l6 6 6-6' : 'M6 15l6-6 6 6'}"/></svg>`;

const marquee = ['Medical Assistant', 'Pharmacy Technician', 'Culinary Arts', 'HVAC / R', 'Medical Billing & Coding', 'Pastry & Baking Arts', 'Business Management', 'Medical Office Administrator'];

const faqs = [
  { q: 'Is FEI accredited?', a: 'Yes. FEI is accredited by the Council on Occupational Education (COE). Some programs, like Pharmacy Technician and HVAC/R, also prepare you for industry-specific certifications or registrations.', open: true },
  { q: 'Is it easy to apply for financial aid?', a: 'Yes it is easy to apply for Financial aid! We have a team dedicated to guiding you step by step through the process. Financial aid is available to those who qualify, including scholarships and payment plans. Our Financial Aid department can walk you through a personalized plan before you commit to anything.' },
  { q: 'How long does it take to complete a program?', a: 'Between 10 to 18 months depending on the program you choose.' },
  { q: 'Do you help with job placement after graduation?', a: 'Yes, of course! Our Career Services team supports graduates with resume help, interview preparation, and connections to employers hiring in Miami.' },
  { q: 'Can I complete my program online?', a: 'Depending on the program selected online may be an option. We recommend meeting with an admissions advisor so they can assist you in picking a program that you enjoy and has a learning format that works for you.' },
  { q: 'What is it like to be a student at FEI?', a: "Amazing! Your professors and FEI's student service department will be there along the way to help get you to graduation and into your new career. You will build camaraderie with fellow classmates as you all strive to achieve your personal goals in the same career field." },
];
---
<BaseLayout
  title="Florida Education Institute, You will Never Be a Number"
  description="Florida Education Institute (FEI) in Miami offers career-focused programs in healthcare, culinary arts, skilled trades and business, with the personal attention that helps you finish and get hired."
  jsonLd={[ORG, websiteSchema(), faqSchema(faqs)]}
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero__bg" style="background-image:url('/img/hero-campus.jpg')" aria-hidden="true"></div>
    <div class="hero__overlay" aria-hidden="true"></div>
    <div class="hero__inner">
      <div class="hero__copy">
        <p class="eyebrow reveal" data-delay="0"><span class="eyebrow__dot"></span> Miami, Florida · Career Education</p>
        <h1 class="hero__title">
          <span class="reveal" data-delay="1">You will never</span>
          <span class="reveal" data-delay="2">be a <em>number.</em></span>
        </h1>
        <p class="hero__lede reveal" data-delay="3"> At Florida Education Institute we know our students by name. Real instructors, hands-on training, and the personal attention that gets you across the finish line, and into a career. </p>
        <div class="hero__cta reveal" data-delay="4">
          <a href="/apply" class="btn btn--solid btn--lg" data-apply>Start today
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M5 12h12.2l-4.6-4.6L14 6l7 7-7 7-1.4-1.4 4.6-4.6H5z"/></svg>
          </a>
          <a href="/programs" class="btn btn--outline btn--lg btn--outline-light">Explore programs</a>
        </div>
        <ul class="hero__proof reveal" data-delay="5">
          <li><strong>11</strong> career programs</li>
          <li><strong>1:1</strong> student attention</li>
          <li><strong>Aid</strong> for those who qualify</li>
        </ul>
      </div>
    </div>
    <div class="hero__chip hero__chip--float reveal" data-delay="4">
      <span class="hero__chip-stars">★★★★★</span>
      <em>"They actually knew me."</em>
    </div>
  </section>

  <!-- marquee -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee__track">
      {[...marquee, ...marquee].map((m) => (<><span>{m}</span><span class="sep">✦</span></>))}
    </div>
  </div>

  <!-- PROGRAMS — compact clickable listing (full catalog at /programs) -->
  <section class="section programs" id="programs">
    <div class="section__head">
      <div>
        <p class="kicker">Programs</p>
        <h2 class="section__title">Pick the career.<br/>We will teach you the skills.</h2>
      </div>
      <a href="/programs" class="link-arrow">View all programs
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="currentColor" d="M5 12h12.2l-4.6-4.6L14 6l7 7-7 7-1.4-1.4 4.6-4.6H5z"/></svg>
      </a>
    </div>
    <ul class="prog-list">
      {PROGRAMS.map((p) => (
        <li>
          <a href={`/programs/${p.slug}`} class="prog-tile reveal" data-cat={p.cat}>
            <span class="prog-tile__icon" aria-hidden="true" set:html={ICONS[p.icon]} />
            <span class="prog-tile__body">
              <span class="prog-tile__name">{p.title}</span>
              <span class="prog-tile__tag">{p.tag}</span>
            </span>
            <svg class="prog-tile__arrow" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- ADVANTAGE -->
  <section class="section advantage" id="advantage">
    <div class="advantage__grid">
      <div class="advantage__intro">
        <p class="kicker kicker--light">The FEI Advantage</p>
        <h2 class="section__title section__title--light">More attention.<br/>Better outcomes.</h2>
        <p class="advantage__lede">The FEI difference is not a slogan, it is a class size. Our instructors and staff know your name, your goals, and are ready to help you along the way.</p>
        <a href="/apply" class="btn btn--coral btn--lg">Meet with an advisor</a>
      </div>
      <div class="advantage__cards">
        <article class="feature"><h3>Personal attention</h3><p>Small classes and real relationships. You will never get lost in a lecture hall.</p></article>
        <article class="feature"><h3>Career education</h3><p>Every program is built around the skills employers in South Florida favor.</p></article>
        <article class="feature"><h3>10 Success Habits</h3><p>Technical training paired with the professional habits.</p></article>
        <article class="feature"><h3>Employer connections</h3><p>Career services, an employer job board, and connections that open doors.</p></article>
      </div>
    </div>
  </section>

  <!-- ADMISSIONS -->
  <section class="section admissions" id="admissions">
    <div class="section__head section__head--center">
      <div>
        <p class="kicker">Admissions</p>
        <h2 class="section__title">Getting started is simple.</h2>
      </div>
    </div>
    <ol class="steps">
      <li class="step"><span class="step__no">1</span><h3>Reach out</h3><p>Call, apply online, or visit the campus. We will answer your questions.</p></li>
      <li class="step"><span class="step__no">2</span><h3>Meet &amp; tour</h3><p>Sit down with an advisor, see the classrooms and labs, and pick your program.</p></li>
      <li class="step"><span class="step__no">3</span><h3>Plan your aid</h3><p>We will help you understand financial aid, scholarships, and what you qualify for.</p></li>
      <li class="step"><span class="step__no">4</span><h3>Enroll</h3><p>Make the choice to change your life with education. Enroll that same day!</p></li>
    </ol>
  </section>

  <!-- FINANCIAL AID -->
  <section class="section aid aid--blue" id="aid">
    <div class="aid__inner">
      <div class="aid__copy">
        <p class="kicker">Financial Aid</p>
        <h2 class="section__title">A new career<br/>is possible!</h2>
        <p class="aid__lede">Financial aid is available to those who qualify. From federal aid to scholarships, our team helps you build a plan that makes attending school a reality.</p>
        <div class="aid__actions">
          <a href="/financial-aid" class="btn btn--solid btn--lg">Find out how</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SUPPORT / TESTIMONIAL (light band to separate from FAQ) -->
  <div class="band band--tint" id="support">
    <section class="section support">
      <figure class="quote">
        <blockquote>“At FEI, I was not a seat in a room. My instructors knew my name, pushed me when I needed it, and helped me land the job I have today.”</blockquote>
        <figcaption>
          <span class="quote__avatar" aria-hidden="true">M</span>
          <span><strong>A recent FEI graduate</strong><em>Healthcare program</em></span>
        </figcaption>
      </figure>
      <div class="support__services">
        <h3>Perpetual Support</h3>
        <ul>
          <li>Student Service department &amp; Student Portal</li>
          <li>Career services &amp; job placement support</li>
          <li>Employer connections &amp; job board</li>
          <li>Expansive Alumni network</li>
        </ul>
      </div>
    </section>
  </div>

  <!-- FAQ -->
  <section class="section faq" id="faq">
    <div class="section__head">
      <div>
        <p class="kicker">FAQ</p>
        <h2 class="section__title">Questions before<br/>you call?</h2>
      </div>
      <p class="section__intro">Here are the answers we get asked most. Anything else, just call us.</p>
    </div>
    <div class="accordion" id="accordion">
      {faqs.map((f) => (
        <div class={`acc-item ${f.open ? 'is-open' : ''}`}>
          <button class="acc-trigger" aria-expanded={f.open ? 'true' : 'false'}>
            <span>{f.q}</span>
            <span class="acc-ico" aria-hidden="true"><Fragment set:html={chev('d') + chev('u')} /></span>
          </button>
          <div class="acc-panel"><p>{f.a}</p></div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA (shared component) -->
  <CtaBlock />
</BaseLayout>
