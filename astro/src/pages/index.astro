---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PROGRAMS, ICONS, CAT_LABELS } from '../data/programs';
import { ORG, websiteSchema, faqSchema } from '../data/schema';

const arrow = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>';
const chev = (dir: 'd' | 'u') =>
  `<svg class="acc-ico__${dir}" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="${dir === 'd' ? 'M6 9l6 6 6-6' : 'M6 15l6-6 6 6'}"/></svg>`;

const marquee = ['Medical Assistant', 'Pharmacy Technician', 'Culinary Arts', 'HVAC / R', 'Medical Billing & Coding', 'Pastry & Baking', 'Business Management', 'Medical Office Administrator'];

const faqs = [
  { q: 'Is FEI accredited?', a: 'Yes. FEI is accredited by the Council on Occupational Education (COE). Some programs, like Pharmacy Technician and HVAC/R, also prepare you for industry-specific certifications or registrations.', open: true },
  { q: 'How much does a program cost, and is financial aid available?', a: 'Cost varies by program. Financial aid is available to those who qualify, including scholarships and payment plans. An advisor can walk you through a personalized breakdown before you commit to anything.' },
  { q: 'How long does it take to complete a program?', a: 'It depends on the path you choose, many of our diploma programs are designed to be completed in under a year, while our A.A.S. degrees run longer. Each program page lists its expected length.' },
  { q: 'Do you help with job placement after graduation?', a: 'Yes. Our Career Services team supports graduates with resume help, interview preparation, and connections to employers hiring in Miami.' },
  { q: 'Can I complete my program online?', a: 'Some programs, like Medical Billing & Coding and Business Management, are offered 100% online. Others, especially culinary and hands-on healthcare programs, are hybrid or in-person to build real skills. Each program page lists its format.' },
  { q: 'What is it like to be a student at FEI?', a: 'Small classes, instructors who know your name, and a team that checks in on how you are actually doing, not just your attendance. That personal attention is the whole reason FEI exists.' },
];
---
<BaseLayout
  title="Florida Education Institute, You will Never Be a Number"
  description="Florida Education Institute (FEI) in Miami offers career-focused programs in healthcare, culinary arts, skilled trades and business, with the personal attention that helps you finish and get hired."
  jsonLd={[ORG, websiteSchema(), faqSchema(faqs)]}
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero__bg" style="background-image:url('/img/hero-campus.jpg')" aria-hidden="true"></div>
    <div class="hero__overlay" aria-hidden="true"></div>
    <div class="hero__inner">
      <div class="hero__copy">
        <p class="eyebrow reveal" data-delay="0"><span class="eyebrow__dot"></span> Miami, Florida · Career Education</p>
        <h1 class="hero__title">
          <span class="reveal" data-delay="1">You will never</span>
          <span class="reveal" data-delay="2">be a <em>number.</em></span>
        </h1>
        <p class="hero__lede reveal" data-delay="3"> At Florida Education Institute we know our students by name. Real instructors, hands-on training, and the personal attention that gets you across the finish line, and into a career. </p>
        <div class="hero__cta reveal" data-delay="4">
          <a href="/apply" class="btn btn--solid btn--lg">Start today
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M5 12h12.2l-4.6-4.6L14 6l7 7-7 7-1.4-1.4 4.6-4.6H5z"/></svg>
          </a>
          <a href="#programs" class="btn btn--outline btn--lg btn--outline-light">Explore programs</a>
        </div>
        <ul class="hero__proof reveal" data-delay="5">
          <li><strong>11</strong> career programs</li>
          <li><strong>1:1</strong> student attention</li>
          <li><strong>Aid</strong> for those who qualify</li>
        </ul>
      </div>
    </div>
    <div class="hero__chip hero__chip--float reveal" data-delay="4">
      <span class="hero__chip-stars">★★★★★</span>
      <em>"They actually knew me."</em>
    </div>
  </section>

  <!-- marquee -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee__track">
      {[...marquee, ...marquee].map((m) => (<><span>{m}</span><span class="sep">✦</span></>))}
    </div>
  </div>

  <!-- PROGRAMS -->
  <section class="section programs" id="programs">
    <div class="section__head">
      <div>
        <p class="kicker">01, Programs</p>
        <h2 class="section__title">Pick the career.<br/>We will teach the craft.</h2>
      </div>
      <p class="section__intro">Eleven focused, career-driven programs across healthcare, culinary arts, skilled trades and business. Short paths, real skills, and instructors who have done the work.</p>
    </div>

    <div class="filters" id="filters" role="group" aria-label="Filter programs">
      <button class="chip is-active" data-filter="all" aria-pressed="true">All</button>
      <button class="chip" data-filter="health" aria-pressed="false">Healthcare</button>
      <button class="chip" data-filter="culinary" aria-pressed="false">Culinary</button>
      <button class="chip" data-filter="trades" aria-pressed="false">Skilled Trades</button>
      <button class="chip" data-filter="business" aria-pressed="false">Business</button>
    </div>

    <div class="prog-grid" id="progGrid">
      {PROGRAMS.map((p) => (
        <article class="card reveal" data-cat={p.cat}>
          <a href={`/programs/${p.slug}`} class="card__media" tabindex="-1" aria-hidden="true">
            <span class="card__badge">{p.tag}</span>
            <img src={`/img/programs/${p.slug}.webp`} alt="" loading="lazy" />
            <span class="card__icon" set:html={ICONS[p.icon]} />
          </a>
          <div class="card__body">
            <span class="card__tag">{CAT_LABELS[p.cat]}</span>
            <h3 class="card__title">{p.title}</h3>
            <p class="card__desc">{p.desc}</p>
            <a href={`/programs/${p.slug}`} class="card__link">Program details<Fragment set:html={arrow} /></a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- ADVANTAGE -->
  <section class="section advantage" id="advantage">
    <div class="advantage__grid">
      <div class="advantage__intro">
        <p class="kicker kicker--light">02, The FEI Advantage</p>
        <h2 class="section__title section__title--light">More attention.<br/>Better outcomes.</h2>
        <p class="advantage__lede">The FEI difference is not a slogan, it is a class size. Our instructors and staff know your name, your goals, and what it takes to get you there.</p>
        <a href="/apply" class="btn btn--coral btn--lg">Meet with an advisor</a>
      </div>
      <div class="advantage__cards">
        <article class="feature"><span class="feature__num">01</span><h3>Personal attention</h3><p>Small classes and real relationships. You will never get lost in a lecture hall.</p></article>
        <article class="feature"><span class="feature__num">02</span><h3>Career education</h3><p>Every program is built around the skills employers in South Florida are hiring for.</p></article>
        <article class="feature"><span class="feature__num">03</span><h3>10 Success Habits</h3><p>Technical training paired with the professional habits that keep you employed.</p></article>
        <article class="feature"><span class="feature__num">04</span><h3>Employer connections</h3><p>Career services, an employer job board, and connections that open doors.</p></article>
      </div>
    </div>
  </section>

  <!-- ADMISSIONS -->
  <section class="section admissions" id="admissions">
    <div class="section__head">
      <div>
        <p class="kicker">03, Admissions</p>
        <h2 class="section__title">Getting started is simple.</h2>
      </div>
      <p class="section__intro">No mystery, no runaround. Four steps and a real person to walk you through each one.</p>
    </div>
    <ol class="steps">
      <li class="step"><span class="step__no">1</span><h3>Reach out</h3><p>Call, apply online, or visit the campus. We will answer your questions honestly.</p></li>
      <li class="step"><span class="step__no">2</span><h3>Meet &amp; tour</h3><p>Sit down with an advisor, see the classrooms and labs, and find your fit.</p></li>
      <li class="step"><span class="step__no">3</span><h3>Plan your aid</h3><p>We will help you understand financial aid, scholarships, and what you qualify for.</p></li>
      <li class="step"><span class="step__no">4</span><h3>Enroll</h3><p>Lock in your start date and step into your program. That is it, you are in.</p></li>
    </ol>
  </section>

  <!-- FINANCIAL AID -->
  <section class="section aid" id="aid">
    <div class="aid__inner">
      <div class="aid__copy">
        <p class="kicker">04, Financial Aid</p>
        <h2 class="section__title">Do not let cost<br/>decide for you.</h2>
        <p class="aid__lede">Financial aid is available to those who qualify. From federal aid to scholarships, our team helps you build a plan that makes your program possible.</p>
        <div class="aid__actions">
          <a href="/apply" class="btn btn--solid btn--lg">Start your application</a>
          <a href="/net-price-calculator" class="link-arrow">Net price calculator
            <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="currentColor" d="M5 12h12.2l-4.6-4.6L14 6l7 7-7 7-1.4-1.4 4.6-4.6H5z"/></svg>
          </a>
        </div>
      </div>
      <div class="aid__stats">
        <div class="stat"><strong>Federal</strong><span>aid for those who qualify</span></div>
        <div class="stat"><strong>Scholarships</strong><span>merit &amp; need-based options</span></div>
        <div class="stat"><strong>1-on-1</strong><span>guidance through every form</span></div>
      </div>
    </div>
  </section>

  <!-- SUPPORT / TESTIMONIAL -->
  <section class="section support" id="support">
    <figure class="quote">
      <blockquote>“At FEI, I was not a seat in a room. My instructors knew my name, pushed me when I needed it, and helped me land the job I have today.”</blockquote>
      <figcaption>
        <span class="quote__avatar" aria-hidden="true">M</span>
        <span><strong>A recent FEI graduate</strong><em>Healthcare program</em></span>
      </figcaption>
    </figure>
    <div class="support__services">
      <h3>Support that follows you through, and after.</h3>
      <ul>
        <li>Career services &amp; job placement support</li>
        <li>Employer connections &amp; job board</li>
        <li>Student portal &amp; online learning (FEI LMS)</li>
        <li>Transcript requests &amp; consumer information</li>
      </ul>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section faq" id="faq">
    <div class="section__head">
      <div>
        <p class="kicker">05, FAQ</p>
        <h2 class="section__title">Questions before<br/>you call?</h2>
      </div>
      <p class="section__intro">Here are the answers we get asked most. Anything else, just call us.</p>
    </div>
    <div class="accordion" id="accordion">
      {faqs.map((f) => (
        <div class={`acc-item ${f.open ? 'is-open' : ''}`}>
          <button class="acc-trigger" aria-expanded={f.open ? 'true' : 'false'}>
            <span>{f.q}</span>
            <span class="acc-ico" aria-hidden="true"><Fragment set:html={chev('d') + chev('u')} /></span>
          </button>
          <div class="acc-panel"><p>{f.a}</p></div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="cta" id="apply">
    <div class="cta__glow" aria-hidden="true"></div>
    <div class="cta__inner">
      <p class="kicker kicker--light">Ready when you are</p>
      <h2 class="cta__title">Your career starts<br/>with one call.</h2>
      <p class="cta__lede">Talk to a real person about programs, start dates, and financial aid. No pressure, just answers.</p>
      <div class="cta__actions">
        <a href="tel:3054441515" class="btn btn--coral btn--lg">Call 305-444-1515</a>
        <a href="/apply" class="btn btn--outline btn--lg btn--outline-light">Apply online</a>
      </div>
    </div>
  </section>
</BaseLayout>
