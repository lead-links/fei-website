---
import BaseLayout from '../layouts/BaseLayout.astro';
import ApplyForm from '../components/ApplyForm.astro';
---
<BaseLayout
  title={"Apply Now | Florida Education Institute"}
  description={"Start your application to Florida Education Institute in Miami. No deadlines, no application fees. Tell us a little about you and an advisor will reach out."}
  forceStuckNav
>
  <section class="section apply-section apply-section--nohero" id="apply-form">
    <div class="apply-grid">
      <div class="apply-intro">
        <p class="kicker">Application</p>
        <h2 class="section__title section__title--sm">Applying is simple.</h2>
        <p class="pblock__text" style="margin-top:1rem">Applying for enrollment at Florida Education Institute was designed to be simple. Completing the application form here begins the enrollment process.</p>
        <p class="pblock__text" style="margin-top:1rem">After applying, we will contact you to set your admissions appointment with one of our Career Education Advisors. We want your education to be life-changing and meaningful to your future, so selecting a career that is right for you will be our first priority.</p>
        <p class="pblock__text" style="margin-top:1rem">We will discuss your goals and find out if Florida Education Institute is right for you. We will give you a tour of our facilities and have you speak with our staff and instructors, who are committed to personal attention and student success. We also encourage you to ask questions, so we can provide you with an education and career plan that you believe in.</p>
        <address class="apply-contact">
          <strong>Florida Education Institute</strong>
          5818 SW 8th Street<br/>
          Miami, FL 33144<br/>
          <a href="tel:3054441515">(305) 444-1515</a><br/>
          <a href="mailto:admissions@fei.edu">admissions@fei.edu</a>
        </address>
        <p class="apply-note">Please note that applying herein does not in any way constitute acceptance to Florida Education Institute.</p>
      </div>

      <ApplyForm prefix="af" formId="applyForm" />

      <div class="apply-success" id="applySuccess" role="status" tabindex="-1" hidden>
        <div class="apply-success__mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="34" height="34" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
        </div>
        <h2 class="section__title section__title--sm">Thank you, <span id="successName">there</span>.</h2>
        <p class="pblock__text">Your application has been received. An FEI Admissions Advisor will reach out soon to walk you through the next steps.</p>
        <p class="pblock__text" style="margin-top:.6rem">Want to talk sooner? Call <a href="tel:3054441515" style="color:var(--blue);font-weight:700">305-444-1515</a>.</p>
        <a href="/" class="btn btn--outline btn--lg" style="margin-top:1.4rem">Back to home</a>
      </div>
    </div>
  </section>
</BaseLayout>
