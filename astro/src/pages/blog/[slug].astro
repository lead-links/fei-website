---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { relatedPrograms, ICONS } from '../../data/programs';
import sanitizeHtml from 'sanitize-html';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((p) => ({ params: { slug: p.data.slug }, props: { post: p, posts } }));
}

const { post, posts } = Astro.props;
const d = post.data;

const clean = sanitizeHtml(d.contentHtml, {
  allowedTags: sanitizeHtml.defaults.allowedTags.concat(['img', 'h1', 'h2', 'figure', 'figcaption', 'iframe']),
  allowedAttributes: {
    ...sanitizeHtml.defaults.allowedAttributes,
    img: ['src', 'alt', 'width', 'height', 'loading'],
    '*': ['class', 'id'],
  },
});

const relatedCourses = relatedPrograms(d);
const dateFmt = new Date(d.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
const primaryCat = d.categories[0];
const heroStyle = d.featuredImage ? `--post-img:url('${d.featuredImage.url}')` : undefined;

// All categories available across the site (deduped).
const allCats = Array.from(
  new Map(posts.flatMap((p) => p.data.categories).map((c) => [c.slug, c])).values()
).sort((a, b) => a.name.localeCompare(b.name));
const catSlugs = new Set(d.categories.map((c) => c.slug));

// Most recent posts in the same category (excluding this one).
const recent = posts
  .filter((p) => p.data.slug !== d.slug && p.data.categories.some((c) => catSlugs.has(c.slug)))
  .sort((a, b) => +new Date(b.data.date) - +new Date(a.data.date))
  .slice(0, 3);
---
<BaseLayout title={d.seo.title ?? d.title} description={d.seo.description} canonical={d.seo.canonicalUrl}>
  {d.seo.jsonLd && <script type="application/ld+json" set:html={d.seo.jsonLd} is:inline />}

  <article class="post">
    <!-- HERO: featured image background + vertical blue gradient, white centered text -->
    <header class="post-hero" style={heroStyle}>
      <div class="post-hero__inner">
        <p class="post-hero__meta">
          {primaryCat && <a href={`/blog/category/${primaryCat.slug}`}>{primaryCat.name}</a>}
          {primaryCat && <span aria-hidden="true">·</span>}
          <span>{dateFmt}</span>
          <span aria-hidden="true">·</span>
          <span>{d.readingTime} min read</span>
        </p>
        <h1 class="post-hero__title">{d.title}</h1>
      </div>
    </header>

    <!-- BODY: content + sidebar, within the standard --wrap main width -->
    <div class="post-body">
      <div class="prose" set:html={clean} />

      <aside class="post-side">
        <div class="side-card">
          <h3>Search the blog</h3>
          <form class="side-search" action="/blog" method="get" role="search">
            <input type="search" name="q" placeholder="Search articles…" aria-label="Search articles" />
            <button type="submit" aria-label="Search">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
            </button>
          </form>
        </div>

        <div class="side-card">
          <h3>Categories</h3>
          <div class="side-tags">
            {allCats.map((c) => (
              <a href={`/blog/category/${c.slug}`} class={`side-tag ${catSlugs.has(c.slug) ? 'is-active' : ''}`}>{c.name}</a>
            ))}
          </div>
        </div>

        {relatedCourses.length > 0 && (
          <div class="side-card">
            <h3>Related courses</h3>
            <ul class="side-courses">
              {relatedCourses.map((p) => (
                <li>
                  <a href={`/programs/${p.slug}`}>
                    <span class="side-courses__ico" set:html={ICONS[p.icon]} />
                    <span class="side-courses__txt"><strong>{p.title}</strong><em>{p.tag}</em></span>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}
      </aside>
    </div>

    <!-- RELATED: most recent in the same category -->
    {recent.length > 0 && (
      <section class="section post-related">
        <div class="section__head">
          <div>
            <p class="kicker">More {primaryCat?.name ?? 'articles'}</p>
            <h2 class="section__title section__title--sm">Latest in {primaryCat?.name ?? 'the blog'}</h2>
          </div>
          <a href={primaryCat ? `/blog/category/${primaryCat.slug}` : '/blog'} class="link-arrow">See all
            <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="currentColor" d="M5 12h12.2l-4.6-4.6L14 6l7 7-7 7-1.4-1.4 4.6-4.6H5z"/></svg>
          </a>
        </div>
        <div class="prog-grid">
          {recent.map((p) => (
            <article class="card">
              <a href={`/blog/${p.data.slug}`} class="card__media" tabindex="-1" aria-hidden="true">
                {p.data.featuredImage && <img src={p.data.featuredImage.url} alt={p.data.featuredImage.alt} loading="lazy" />}
              </a>
              <div class="card__body">
                <span class="card__tag">{p.data.categories.map((c) => c.name).join(', ') || 'Blog'}</span>
                <h3 class="card__title"><a href={`/blog/${p.data.slug}`}>{p.data.title}</a></h3>
                <p class="card__desc" set:html={p.data.excerptHtml} />
                <a href={`/blog/${p.data.slug}`} class="card__link">Read more</a>
              </div>
            </article>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .post { --post-tint: #e9f1fc; }

  /* BODY — content + sidebar, both inside the standard --wrap main width */
  .post-body {
    max-width: var(--wrap);
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 4rem) var(--pad) clamp(2.5rem, 5vw, 4rem);
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: start;
  }

  .prose { min-width: 0; font-size: 1.06rem; color: var(--slate); line-height: 1.75; }
  .prose :global(h2) { font-family: var(--display); color: var(--navy); font-size: 1.55rem; margin: 2.2rem 0 .7rem; }
  .prose :global(h3) { font-family: var(--display); color: var(--navy); font-size: 1.2rem; margin: 1.6rem 0 .5rem; }
  .prose :global(p) { margin: 0 0 1.15rem; }
  .prose :global(ul), .prose :global(ol) { margin: 0 0 1.2rem 1.3rem; }
  .prose :global(li) { margin: .35rem 0; }
  .prose :global(img) { max-width: 100%; height: auto; margin: 1.2rem 0; }
  .prose :global(a) { color: var(--blue-600); text-decoration: underline; }

  .post-side { position: sticky; top: 120px; display: flex; flex-direction: column; gap: 1rem; }
  .side-card { background: var(--white); border: 1px solid var(--line); padding: 1.2rem 1.3rem; }
  .side-card h3 { font-family: var(--display); font-size: .95rem; font-weight: 800; color: var(--navy); margin: 0 0 .9rem; }
  .side-search { display: flex; border: 1px solid var(--line); }
  .side-search input { flex: 1; min-width: 0; border: 0; padding: .6em .8em; font: inherit; font-size: .9rem; background: transparent; color: var(--navy); }
  .side-search input:focus { outline: 2px solid var(--blue); outline-offset: -2px; }
  .side-search button { border: 0; background: var(--blue); color: #fff; padding: 0 .9em; cursor: pointer; display: grid; place-items: center; }
  .side-tags { display: flex; flex-wrap: wrap; gap: .5rem; }
  .side-tag { font-size: .82rem; font-weight: 600; color: var(--blue-600); background: var(--post-tint); border: 1px solid #dbe8f7; padding: .35em .8em; }
  .side-tag:hover { background: #dbe8f7; }
  .side-tag.is-active { background: var(--blue); border-color: var(--blue); color: #fff; }
  .side-courses { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: .4rem; }
  .side-courses a { display: flex; align-items: center; gap: .7rem; padding: .55rem; border: 1px solid transparent; transition: border-color .2s, background .2s; }
  .side-courses a:hover { border-color: var(--line); background: var(--bg); }
  .side-courses__ico { flex-shrink: 0; width: 34px; height: 34px; display: grid; place-items: center; background: var(--navy); color: var(--gold); }
  .side-courses__ico :global(svg) { width: 18px; height: 18px; }
  .side-courses__txt { display: flex; flex-direction: column; line-height: 1.25; }
  .side-courses strong { font-family: var(--display); font-size: .92rem; color: var(--navy); font-weight: 700; }
  .side-courses em { font-style: normal; font-size: .74rem; color: var(--gray); }

  .post-related { border-top: 1px solid var(--line); }

  @media (max-width: 900px) {
    .post-body { grid-template-columns: 1fr; }
    .post-side { position: static; }
  }
</style>
