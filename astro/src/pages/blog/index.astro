---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogBar from '../../components/BlogBar.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => +new Date(b.data.date) - +new Date(a.data.date)
);
---
<BaseLayout title="Blog | Florida Education Institute" description="Career guides and news from Florida Education Institute in Miami.">
  <!-- HERO — same model as the single post header -->
  <header class="post-hero" style="--post-img:url('/img/students.jpg')">
    <div class="post-hero__inner">
      <p class="post-hero__meta"><span>The FEI Blog</span></p>
      <h1 class="post-hero__title">Career guides &amp; news</h1>
      <p class="post-hero__lede">Practical guides on careers, training, and getting hired, from the FEI team.</p>
    </div>
  </header>

  <!-- Search + categories in the blue bar, right under the hero -->
  <BlogBar activeCat={null} />

  <section class="section">
    <div class="prog-grid">
      {posts.map((p) => (
        <article class="card">
          <a href={`/blog/${p.data.slug}`} class="card__media" tabindex="-1" aria-hidden="true">
            {p.data.featuredImage && <img src={p.data.featuredImage.url} alt={p.data.featuredImage.alt} loading="lazy" />}
          </a>
          <div class="card__body">
            <span class="card__tag">{p.data.categories.map((c) => c.name).join(', ') || 'Blog'}</span>
            <h3 class="card__title"><a href={`/blog/${p.data.slug}`}>{p.data.title}</a></h3>
            <p class="card__desc" set:html={p.data.excerptHtml} />
            <a href={`/blog/${p.data.slug}`} class="card__link">Read more</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
