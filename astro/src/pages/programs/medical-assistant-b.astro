---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { PROGRAM_META } from '../../data/program-meta';
import maHtml from '../../data/programs/medical-assistant.html?raw';

// A/B variant B of /programs/medical-assistant: identical to the original program
// page, EXCEPT the hero — the CTA buttons are replaced by an inline pre-registration
// form (step 1 of 2), and the program facts move up into the hero where the buttons
// were. Everything below the hero is the original content, rendered verbatim.
const meta = PROGRAM_META['medical-assistant'];
const program = 'Medical Assistant';
const programType = 'Diploma';
const nextStep = '/programs/medical-assistant-b/apply';

// Original page content, minus the hero + factbar (everything after the factbar's </aside>).
const belowHero = maHtml.split('</aside>').slice(1).join('</aside>');
---
<BaseLayout title={meta.title} description={meta.description} noindex>
  <!-- Program context for the in-content Apply modal (unchanged from the original) -->
  <div id="feiProgramMeta" data-program={program} data-program-type={programType} hidden></div>

  <!-- HERO (variant B): copy + facts on the left, inline pre-registration form on the right -->
  <section class="phero phero--b">
    <div class="hero__bg" style="--hero-d:url('/img/programs/medical-assistant.webp'); --hero-m:url('/img/programs/mobile/medical-assistant.webp')" aria-hidden="true"></div>
    <div class="hero__overlay" aria-hidden="true"></div>
    <div class="phero__inner">
      <div class="phero__copy">
        <p class="eyebrow"><span class="eyebrow__dot"></span> Healthcare Program</p>
        <h1 class="phero__title">Medical Assistant</h1>
        <p class="phero__lede">Clinical and administrative skills for physician offices, clinics, and urgent care, trained hands-on, hybrid, and close to home.</p>

        <ul class="phero-facts">
          <li>
            <span class="phero-facts__ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/></svg></span>
            <span class="phero-facts__txt"><strong>In Under a Year</strong><span>Program length</span></span>
          </li>
          <li>
            <span class="phero-facts__ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 3l8 4-8 4-8-4 8-4z"/><path d="M4 11v5c0 1.7 3.6 3 8 3s8-1.3 8-3v-5"/></svg></span>
            <span class="phero-facts__txt"><strong>Diploma</strong><span>Credential earned</span></span>
          </li>
          <li>
            <span class="phero-facts__ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M3 9h18M8 4v3M16 4v3"/></svg></span>
            <span class="phero-facts__txt"><strong>Hybrid</strong><span>Online + externship</span></span>
          </li>
          <li>
            <span class="phero-facts__ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 21s-7-5.2-7-11a7 7 0 0 1 14 0c0 5.8-7 11-7 11z"/><circle cx="12" cy="10" r="2.5"/></svg></span>
            <span class="phero-facts__txt"><strong>Miami</strong><span>Campus</span></span>
          </li>
        </ul>
      </div>

      <div class="phero-form">
        <p class="phero-form__eyebrow">Apply to FEI</p>
        <h2 class="phero-form__title">Request program details</h2>
        <p class="phero-form__sub">Tell us a little about you and an Admissions Advisor will reach out. No obligation.</p>

        <form
          class="form"
          id="preRegForm"
          novalidate
          data-program={program}
          data-program-type={programType}
          data-next={nextStep}
          data-msg-required="This field is required."
          data-msg-invalid-email="Enter a valid email address."
          data-msg-invalid-phone="Enter a valid phone number."
          data-msg-error-summary="Please fix the following before submitting:"
        >
          <div class="form-summary" id="pr-summary" role="alert" tabindex="-1" hidden></div>

          <div class="field">
            <label for="pr-first">First name</label>
            <input type="text" id="pr-first" name="firstName" autocomplete="given-name" required aria-describedby="pr-first-error" />
            <p class="field-error" id="pr-first-error" hidden></p>
          </div>
          <div class="field">
            <label for="pr-last">Last name</label>
            <input type="text" id="pr-last" name="lastName" autocomplete="family-name" required aria-describedby="pr-last-error" />
            <p class="field-error" id="pr-last-error" hidden></p>
          </div>
          <div class="field">
            <label for="pr-email">Email</label>
            <input type="email" id="pr-email" name="email" autocomplete="email" required aria-describedby="pr-email-error" />
            <p class="field-error" id="pr-email-error" hidden></p>
          </div>
          <div class="field">
            <label for="pr-phone">Phone</label>
            <input type="tel" id="pr-phone" name="phone" autocomplete="tel" aria-describedby="pr-phone-error" />
            <p class="field-error" id="pr-phone-error" hidden></p>
          </div>

          <button type="submit" class="btn btn--solid phero-form__submit">Apply
            <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="currentColor" d="M5 12h12.2l-4.6-4.6L14 6l7 7-7 7-1.4-1.4 4.6-4.6H5z"/></svg>
          </button>
          <p class="form-error" id="pr-error" role="alert" hidden>Sorry — we couldn't submit. Please try again, or call <a href="tel:3054441515">305-444-1515</a>.</p>
        </form>
      </div>
    </div>
  </section>

  <Fragment set:html={belowHero} />
</BaseLayout>
