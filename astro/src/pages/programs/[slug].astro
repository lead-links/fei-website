---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { PROGRAM_META } from '../../data/program-meta';
import { PROGRAMS } from '../../data/programs';

// Each program's <main> content, ported verbatim from the current site.
const contents = import.meta.glob('../../data/programs/*.html', {
  query: '?raw',
  import: 'default',
  eager: true,
}) as Record<string, string>;

export function getStaticPaths() {
  return Object.keys(PROGRAM_META).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const meta = PROGRAM_META[slug as string];
const key = Object.keys(contents).find((k) => k.endsWith(`/${slug}.html`))!;
const html = contents[key];

// Program context for the Apply modal (read by site.js to fill hidden fields).
const program = PROGRAMS.find((p) => p.slug === slug);
const programType = program?.tag === 'A.A.S.' ? 'Associate Degree' : (program?.tag ?? '');
---
<BaseLayout title={meta.title} description={meta.description}>
  {program && (
    <div id="feiProgramMeta" data-program={program.title} data-program-type={programType} hidden></div>
  )}
  <Fragment set:html={html} />
</BaseLayout>
