---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { PROGRAMS, ICONS } from '../../data/programs';
import { PROGRAM_ES, PROGRAM_TITLE_ES, PROGRAM_DESC_ES, CAT_LABELS_ES } from '../../i18n/routes';
import { breadcrumbSchema, SITE } from '../../data/schema';

// Índice de programas en español (/es/programas): el mismo catálogo de la
// sección "Programas" de la home, como página independiente e indexable.
// Espejo de /programs; BaseLayout detecta el idioma por la URL (/es/...).
const arrow = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>';

const jsonLd = [
  breadcrumbSchema([
    { name: 'Inicio', url: `${SITE}/es` },
    { name: 'Programas', url: `${SITE}/es/programas` },
  ]),
];
---
<BaseLayout
  title="Programas Profesionales en Miami | Florida Education Institute"
  description="Explora 11 programas profesionales de diploma y grado asociado en Florida Education Institute en Miami: salud, artes culinarias, oficios especializados y negocios."
  jsonLd={jsonLd}
>
  <!-- HERO -->
  <section class="phero phero--page">
    <div class="hero__bg" style="background-image:url('/img/students.jpg')" aria-hidden="true"></div>
    <div class="hero__overlay" aria-hidden="true"></div>
    <div class="phero__inner">
      <div class="phero__copy">
        <p class="eyebrow reveal" data-delay="0"><span class="eyebrow__dot"></span> Miami, Florida · Educación Profesional</p>
        <h1 class="phero__title reveal" data-delay="1">Elige la carrera.<br/>Nosotros enseñamos el oficio.</h1>
        <p class="phero__lede reveal" data-delay="2">Once programas enfocados y orientados a la carrera en salud, artes culinarias, oficios especializados y negocios. Caminos cortos, habilidades reales e instructores que han hecho el trabajo.</p>
        <div class="hero__cta reveal" data-delay="3">
          <a href="#programs" class="btn btn--solid btn--lg">Explora los programas
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M5 12h12.2l-4.6-4.6L14 6l7 7-7 7-1.4-1.4 4.6-4.6H5z"/></svg>
          </a>
          <a href="/es/inscripcion" class="btn btn--outline btn--lg btn--outline-light">Solicita ahora</a>
        </div>
      </div>
    </div>
  </section>

  <!-- GRID DE PROGRAMAS -->
  <section class="section programs" id="programs">
    <div class="filters" id="filters" role="group" aria-label="Filtrar programas">
      <button class="chip is-active" data-filter="all" aria-pressed="true">Todos</button>
      <button class="chip" data-filter="health" aria-pressed="false">Salud</button>
      <button class="chip" data-filter="culinary" aria-pressed="false">Culinaria</button>
      <button class="chip" data-filter="trades" aria-pressed="false">Oficios</button>
      <button class="chip" data-filter="business" aria-pressed="false">Negocios</button>
    </div>

    <div class="prog-grid" id="progGrid">
      {PROGRAMS.map((p) => (
        <article class="card reveal" data-cat={p.cat}>
          <a href={`/es/programas/${PROGRAM_ES[p.slug]}`} class="card__media" tabindex="-1" aria-hidden="true">
            <span class="card__badge">{p.tag}</span>
            <img src={`/img/programs/${p.slug}.webp`} alt="" loading="lazy" />
            <span class="card__icon" set:html={ICONS[p.icon]} />
          </a>
          <div class="card__body">
            <span class="card__tag">{CAT_LABELS_ES[p.cat]}</span>
            <h3 class="card__title">{PROGRAM_TITLE_ES[p.slug]}</h3>
            <p class="card__desc">{PROGRAM_DESC_ES[p.slug]}</p>
            <a href={`/es/programas/${PROGRAM_ES[p.slug]}`} class="card__link">Detalles del programa<Fragment set:html={arrow} /></a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="cta" id="apply">
    <div class="cta__glow" aria-hidden="true"></div>
    <div class="cta__inner">
      <p class="kicker kicker--light">Listos cuando tú lo estés</p>
      <h2 class="cta__title">Tu carrera empieza<br/>con una llamada.</h2>
      <p class="cta__lede">Habla con una persona real sobre programas, fechas de inicio y ayuda financiera. Sin presión, solo respuestas.</p>
      <div class="cta__actions">
        <a href="tel:3054441515" class="btn btn--coral btn--lg">Llama al 305-444-1515</a>
        <a href="/es/inscripcion" class="btn btn--outline btn--lg btn--outline-light">Solicita en línea</a>
      </div>
    </div>
  </section>
</BaseLayout>
