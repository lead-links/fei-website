---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { PROGRAMS, ICONS } from '../../data/programs';
import { PROGRAM_ES, PROGRAM_TITLE_ES } from '../../i18n/routes';
import { ORG, websiteSchema, faqSchema } from '../../data/schema';
import CtaBlock from '../../components/CtaBlock.astro';

const chev = (dir: 'd' | 'u') =>
  `<svg class="acc-ico__${dir}" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="${dir === 'd' ? 'M6 9l6 6 6-6' : 'M6 15l6-6 6 6'}"/></svg>`;

const marquee = ['Asistente Médico', 'Técnico de Farmacia', 'Artes Culinarias', 'Climatización y Refrigeración', 'Facturación y Codificación Médica', 'Repostería y Panadería', 'Gestión Empresarial', 'Administrador de Oficina Médica'];

const faqs = [
  { q: '¿FEI está acreditado?', a: 'Sí. FEI está acreditado por el Council on Occupational Education (COE). Algunos programas, como Técnico de Farmacia y Climatización y Refrigeración (HVAC/R), también te preparan para certificaciones o registros específicos de la industria.', open: true },
  { q: '¿Es fácil solicitar ayuda financiera?', a: '¡Sí, es fácil solicitar ayuda financiera! Tenemos un equipo dedicado a guiarte paso a paso en el proceso. La ayuda financiera está disponible para quienes califiquen, incluyendo becas y planes de pago. Nuestro Departamento de Ayuda Financiera puede explicarte un plan personalizado antes de que te comprometas a nada.' },
  { q: '¿Cuánto tiempo toma completar un programa?', a: 'Entre 10 y 18 meses según el programa que elijas.' },
  { q: '¿Ayudan con la colocación laboral después de graduarse?', a: '¡Sí, claro! Nuestro equipo de Servicios de Carrera apoya a los graduados con ayuda para el currículum, preparación para entrevistas y conexiones con empleadores que contratan en Miami.' },
  { q: '¿Puedo completar mi programa en línea?', a: 'Según el programa seleccionado, en línea puede ser una opción. Te recomendamos reunirte con un asesor de admisiones para que te ayude a elegir un programa que disfrutes y con un formato de aprendizaje que funcione para ti.' },
  { q: '¿Cómo es ser estudiante en FEI?', a: '¡Increíble! Tus profesores y el departamento de servicios al estudiante de FEI estarán ahí en el camino para ayudarte a graduarte y a comenzar tu nueva carrera. Construirás camaradería con tus compañeros mientras todos se esfuerzan por alcanzar sus metas personales en el mismo campo profesional.' },
];
---
<BaseLayout
  title="Florida Education Institute, Nunca Serás un Número"
  description="Florida Education Institute (FEI), en Miami, ofrece programas orientados a la carrera en salud, artes culinarias, oficios especializados y negocios, con la atención personalizada que te ayuda a terminar y conseguir empleo."
  jsonLd={[ORG, websiteSchema(), faqSchema(faqs)]}
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero__bg" style="background-image:url('/img/hero-campus.jpg')" aria-hidden="true"></div>
    <div class="hero__overlay" aria-hidden="true"></div>
    <div class="hero__inner">
      <div class="hero__copy">
        <p class="eyebrow reveal" data-delay="0"><span class="eyebrow__dot"></span> Miami, Florida · Educación Profesional</p>
        <h1 class="hero__title">
          <span class="reveal" data-delay="1">Nunca serás</span>
          <span class="reveal" data-delay="2">un <em>número.</em></span>
        </h1>
        <p class="hero__lede reveal" data-delay="3"> En Florida Education Institute conocemos a nuestros estudiantes por su nombre. Instructores de verdad, formación práctica y la atención personalizada que te lleva hasta la meta, y hasta una carrera. </p>
        <div class="hero__cta reveal" data-delay="4">
          <a href="/es/inscripcion" class="btn btn--solid btn--lg" data-apply>Empieza hoy
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="currentColor" d="M5 12h12.2l-4.6-4.6L14 6l7 7-7 7-1.4-1.4 4.6-4.6H5z"/></svg>
          </a>
          <a href="/es/programas" class="btn btn--outline btn--lg btn--outline-light">Explora los programas</a>
        </div>
        <ul class="hero__proof reveal" data-delay="5">
          <li><strong>11</strong> programas de carrera</li>
          <li><strong>1:1</strong> atención al estudiante</li>
          <li><strong>Ayuda</strong> para quienes califiquen</li>
        </ul>
      </div>
    </div>
    <div class="hero__chip hero__chip--float reveal" data-delay="4">
      <span class="hero__chip-stars">★★★★★</span>
      <em>"De verdad me conocían."</em>
    </div>
  </section>

  <!-- marquee -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee__track">
      {[...marquee, ...marquee].map((m) => (<><span>{m}</span><span class="sep">✦</span></>))}
    </div>
  </div>

  <!-- PROGRAMAS — listado compacto y clicable (catálogo completo en /es/programas) -->
  <section class="section programs" id="programs">
    <div class="section__head">
      <div>
        <p class="kicker">Programas</p>
        <h2 class="section__title">Elige la carrera.<br/>Te enseñamos las habilidades.</h2>
      </div>
      <a href="/es/programas" class="link-arrow">Ver todos los programas
        <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="currentColor" d="M5 12h12.2l-4.6-4.6L14 6l7 7-7 7-1.4-1.4 4.6-4.6H5z"/></svg>
      </a>
    </div>
    <ul class="prog-list">
      {PROGRAMS.map((p) => (
        <li>
          <a href={`/es/programas/${PROGRAM_ES[p.slug]}`} class="prog-tile reveal" data-cat={p.cat}>
            <span class="prog-tile__icon" aria-hidden="true" set:html={ICONS[p.icon]} />
            <span class="prog-tile__body">
              <span class="prog-tile__name">{PROGRAM_TITLE_ES[p.slug]}</span>
              <span class="prog-tile__tag">{p.tag}</span>
            </span>
            <svg class="prog-tile__arrow" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- ADVANTAGE -->
  <section class="section advantage" id="advantage">
    <div class="advantage__grid">
      <div class="advantage__intro">
        <p class="kicker kicker--light">La Ventaja FEI</p>
        <h2 class="section__title section__title--light">Más atención.<br/>Mejores resultados.</h2>
        <p class="advantage__lede">La diferencia FEI no es un eslogan, es el tamaño de la clase. Nuestros instructores y personal conocen tu nombre, tus metas y están listos para ayudarte en el camino.</p>
        <a href="/es/inscripcion" class="btn btn--coral btn--lg">Reúnete con un asesor</a>
      </div>
      <div class="advantage__cards">
        <article class="feature"><h3>Atención personalizada</h3><p>Clases pequeñas y relaciones reales. Nunca te perderás en un salón lleno.</p></article>
        <article class="feature"><h3>Educación profesional</h3><p>Cada programa se construye en torno a las habilidades que prefieren los empleadores del sur de la Florida.</p></article>
        <article class="feature"><h3>10 Hábitos de Éxito</h3><p>Formación técnica combinada con los hábitos profesionales.</p></article>
        <article class="feature"><h3>Conexiones con empleadores</h3><p>Servicios de carrera, una bolsa de empleo de empleadores y conexiones que abren puertas.</p></article>
      </div>
    </div>
  </section>

  <!-- ADMISSIONS -->
  <section class="section admissions" id="admissions">
    <div class="section__head section__head--center">
      <div>
        <p class="kicker">Admisiones</p>
        <h2 class="section__title">Comenzar es sencillo.</h2>
      </div>
    </div>
    <ol class="steps">
      <li class="step"><span class="step__no">1</span><h3>Comunícate</h3><p>Llama, solicita en línea o visita el campus. Responderemos tus preguntas.</p></li>
      <li class="step"><span class="step__no">2</span><h3>Reúnete y recorre</h3><p>Siéntate con un asesor, conoce las aulas y los laboratorios, y elige tu programa.</p></li>
      <li class="step"><span class="step__no">3</span><h3>Planifica tu ayuda</h3><p>Te ayudaremos a entender la ayuda financiera, las becas y para qué calificas.</p></li>
      <li class="step"><span class="step__no">4</span><h3>Inscríbete</h3><p>Toma la decisión de cambiar tu vida con la educación. ¡Inscríbete ese mismo día!</p></li>
    </ol>
  </section>

  <!-- FINANCIAL AID -->
  <section class="section aid aid--blue" id="aid">
    <div class="aid__inner">
      <div class="aid__copy">
        <p class="kicker">Ayuda Financiera</p>
        <h2 class="section__title">¡Una nueva carrera<br/>es posible!</h2>
        <p class="aid__lede">La ayuda financiera está disponible para quienes califiquen. De la ayuda federal a las becas, nuestro equipo te ayuda a crear un plan que haga realidad estudiar.</p>
        <div class="aid__actions">
          <a href="/es/ayuda-financiera" class="btn btn--solid btn--lg">Descubre cómo</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SUPPORT / TESTIMONIAL (faixa clara para separar del FAQ) -->
  <div class="band band--tint" id="support">
    <section class="section support">
      <figure class="quote">
        <blockquote>“En FEI no era un asiento en un salón. Mis instructores sabían mi nombre, me exigían cuando lo necesitaba y me ayudaron a conseguir el empleo que tengo hoy.”</blockquote>
        <figcaption>
          <span class="quote__avatar" aria-hidden="true">M</span>
          <span><strong>Una graduada reciente de FEI</strong><em>Programa de salud</em></span>
        </figcaption>
      </figure>
      <div class="support__services">
        <h3>Apoyo Perpetuo</h3>
        <ul>
          <li>Departamento de Servicios al Estudiante y Portal del Estudiante</li>
          <li>Servicios de carrera y apoyo para colocación laboral</li>
          <li>Conexiones con empleadores y bolsa de empleo</li>
          <li>Amplia red de exalumnos</li>
        </ul>
      </div>
    </section>
  </div>

  <!-- FAQ -->
  <section class="section faq" id="faq">
    <div class="section__head">
      <div>
        <p class="kicker">Preguntas frecuentes</p>
        <h2 class="section__title">¿Preguntas antes<br/>de llamar?</h2>
      </div>
      <p class="section__intro">Estas son las respuestas que más nos piden. Para cualquier otra cosa, solo llámanos.</p>
    </div>
    <div class="accordion" id="accordion">
      {faqs.map((f) => (
        <div class={`acc-item ${f.open ? 'is-open' : ''}`}>
          <button class="acc-trigger" aria-expanded={f.open ? 'true' : 'false'}>
            <span>{f.q}</span>
            <span class="acc-ico" aria-hidden="true"><Fragment set:html={chev('d') + chev('u')} /></span>
          </button>
          <div class="acc-panel"><p>{f.a}</p></div>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA (compartido) -->
  <CtaBlock />
</BaseLayout>
