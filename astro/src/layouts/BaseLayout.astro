---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ApplyModal from '../components/ApplyModal.astro';
import { locales, type Lang } from '../i18n/routes';
import { t } from '../i18n/ui';
import { readFileSync } from 'node:fs';
import { createHash } from 'node:crypto';
import { join } from 'node:path';

// site.js is served as-is from public/ (not through Astro's hashed asset pipeline),
// so a CDN/browser cache can pin an old copy indefinitely across deploys. A
// content hash query string forces a new URL — and a fresh fetch — whenever the
// file actually changes, without needing a manual cache purge on every deploy.
// process.cwd() (not import.meta.url) because Astro relocates the compiled
// component into dist/ chunks, breaking any path relative to the source file.
const siteJsHash = createHash('md5').update(readFileSync(join(process.cwd(), 'public', 'site.js'))).digest('hex').slice(0, 8);

interface Props {
  title: string;
  description?: string | null;
  canonical?: string | null;
  image?: string | null;   // absolute URL used as the social share image (og:image)
  ogType?: string;
  hideFooter?: boolean;    // full-bleed pages (e.g. embedded tools) that render no footer
  forceStuckNav?: boolean; // render the nav permanently solid (no dark hero behind it)
  noindex?: boolean;       // thin/utility pages (search, calculator, 404) — keep out of the index
  jsonLd?: object | object[]; // structured data (schema.org) objects to emit as ld+json
  publishedTime?: string | null; // article:published_time (blog posts)
  modifiedTime?: string | null;  // article:modified_time (blog posts)
  author?: string | null;        // article:author (blog posts)
}
const {
  title, description, canonical, image, ogType = 'website',
  hideFooter = false, forceStuckNav = false, noindex = false,
  jsonLd, publishedTime, modifiedTime, author,
} = Astro.props;
// Clean URL for og:url — strip the built .html/index.html so it matches the site's clean links.
const cleanPath = Astro.url.pathname.replace(/index\.html$/, '').replace(/\.html$/, '');
const pageUrl = Astro.site ? new URL(cleanPath, Astro.site).href : (canonical ?? undefined);
// Self-referencing canonical: default to this page's own apex URL. Because pageUrl
// is built from Astro.site (https://fei.edu), every page canonicalizes to the apex
// host regardless of whether www or apex served it — neutralizing the www duplicate.
const canonicalUrl = canonical ?? pageUrl;
// Social share image: fall back to a branded default so pages without a per-page
// image still get a large image card instead of Twitter's text-only summary.
const ogImage = image ?? (Astro.site ? new URL('/og-default.jpg', Astro.site).href : undefined);
// i18n: derive language + the EN/ES counterparts for hreflang.
const alt = locales(Astro.url.pathname);
const lang: Lang = alt.isEs ? 'es' : 'en';
const ogLocale = lang === 'es' ? 'es_ES' : 'en_US';
const ogLocaleAlt = lang === 'es' ? 'en_US' : 'es_ES';
const normPath = cleanPath.length > 1 ? cleanPath.replace(/\/$/, '') : cleanPath;
// English-only pages (no ES counterpart) — skip hreflang alternates for these.
const isEnglishOnly = normPath === '/blog' || normPath.startsWith('/blog/');
const enUrl = Astro.site ? new URL(alt.en, Astro.site).href : null;
const esUrl = Astro.site ? new URL(alt.es, Astro.site).href : null;
const jsonLdBlocks = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-TR7MCFQ');</script>
    <!-- End Google Tag Manager -->
    <meta name="theme-color" content="#1A202C" />
    <!-- Favicons (FEI brand mark) -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {noindex && <meta name="robots" content="noindex,follow" />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {!isEnglishOnly && enUrl && <link rel="alternate" hreflang="en" href={enUrl} />}
    {!isEnglishOnly && esUrl && <link rel="alternate" hreflang="es" href={esUrl} />}
    {!isEnglishOnly && enUrl && <link rel="alternate" hreflang="x-default" href={enUrl} />}
    <!-- Open Graph / Twitter — social share preview -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Florida Education Institute" />
    <meta property="og:locale" content={ogLocale} />
    {!isEnglishOnly && <meta property="og:locale:alternate" content={ogLocaleAlt} />}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {pageUrl && <meta property="og:url" content={pageUrl} />}
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta property="og:image:alt" content={title} />}
    {ogType === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {ogType === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {ogType === 'article' && author && <meta property="article:author" content={author} />}
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    {jsonLdBlocks.map((block) => (
      <script type="application/ld+json" is:inline set:html={JSON.stringify(block)} />
    ))}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/vendor/intl-tel-input/css/intlTelInput.min.css" />
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TR7MCFQ" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <a href="#top" class="sr-only sr-only-focusable">{t(lang).nav.skipToContent}</a>
    <div class="grain" aria-hidden="true"></div>
    <SiteHeader forceStuck={forceStuckNav} />
    <main id="top" tabindex="-1"><slot /></main>
    {!hideFooter && <SiteFooter />}
    <ApplyModal lang={lang} />
    <script src="/vendor/intl-tel-input/js/intlTelInputWithUtils.min.js" defer is:inline></script>
    <script src={`/site.js?v=${siteJsHash}`} defer is:inline></script>
  </body>
</html>
