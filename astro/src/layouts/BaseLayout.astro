---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ApplyModal from '../components/ApplyModal.astro';

interface Props {
  title: string;
  description?: string | null;
  lang?: string;
  canonical?: string | null;
}
const { title, description, lang = 'en', canonical } = Astro.props;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1A202C" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="grain" aria-hidden="true"></div>
    <SiteHeader />
    <main id="top"><slot /></main>
    <SiteFooter />
    <ApplyModal />
    <script src="/site.js" defer is:inline></script>
  </body>
</html>
