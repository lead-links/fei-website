---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import ApplyModal from '../components/ApplyModal.astro';
import { locales, type Lang } from '../i18n/routes';
import { t } from '../i18n/ui';

interface Props {
  title: string;
  description?: string | null;
  canonical?: string | null;
  image?: string | null;   // absolute URL used as the social share image (og:image)
  ogType?: string;
  hideFooter?: boolean;    // full-bleed pages (e.g. embedded tools) that render no footer
  forceStuckNav?: boolean; // render the nav permanently solid (no dark hero behind it)
}
const { title, description, canonical, image, ogType = 'website', hideFooter = false, forceStuckNav = false } = Astro.props;
// Clean URL for og:url — strip the built .html/index.html so it matches the site's clean links.
const cleanPath = Astro.url.pathname.replace(/index\.html$/, '').replace(/\.html$/, '');
const pageUrl = Astro.site ? new URL(cleanPath, Astro.site).href : (canonical ?? undefined);
// i18n: derive language + the EN/ES counterparts for hreflang.
const alt = locales(Astro.url.pathname);
const lang: Lang = alt.isEs ? 'es' : 'en';
const normPath = cleanPath.length > 1 ? cleanPath.replace(/\/$/, '') : cleanPath;
// English-only pages (no ES counterpart) — skip hreflang alternates for these.
const isEnglishOnly = normPath === '/blog' || normPath.startsWith('/blog/');
const enUrl = Astro.site ? new URL(alt.en, Astro.site).href : null;
const esUrl = Astro.site ? new URL(alt.es, Astro.site).href : null;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-TR7MCFQ');</script>
    <!-- End Google Tag Manager -->
    <meta name="theme-color" content="#1A202C" />
    <!-- Favicons (FEI brand mark) -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    {canonical && <link rel="canonical" href={canonical} />}
    {!isEnglishOnly && enUrl && <link rel="alternate" hreflang="en" href={enUrl} />}
    {!isEnglishOnly && esUrl && <link rel="alternate" hreflang="es" href={esUrl} />}
    {!isEnglishOnly && enUrl && <link rel="alternate" hreflang="x-default" href={enUrl} />}
    <!-- Open Graph / Twitter — social share preview -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Florida Education Institute" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    {pageUrl && <meta property="og:url" content={pageUrl} />}
    {image && <meta property="og:image" content={image} />}
    {image && <meta property="og:image:alt" content={title} />}
    <meta name="twitter:card" content={image ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    {image && <meta name="twitter:image" content={image} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,600&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/vendor/intl-tel-input/css/intlTelInput.min.css" />
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-TR7MCFQ" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <a href="#top" class="sr-only sr-only-focusable">{t(lang).nav.skipToContent}</a>
    <div class="grain" aria-hidden="true"></div>
    <SiteHeader forceStuck={forceStuckNav} />
    <main id="top" tabindex="-1"><slot /></main>
    {!hideFooter && <SiteFooter />}
    <ApplyModal lang={lang} />
    <script src="/vendor/intl-tel-input/js/intlTelInputWithUtils.min.js" defer is:inline></script>
    <script src="/site.js" defer is:inline></script>
  </body>
</html>
