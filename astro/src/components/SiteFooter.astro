---
import { href, locales, type Lang } from '../i18n/routes';
import { t } from '../i18n/ui';

const isEs = locales(Astro.url.pathname).isEs;
const lang: Lang = isEs ? 'es' : 'en';
const f = t(lang).footer;
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="footer__inner">
    <div class="footer__brand">
      <span class="brand__text brand__text--footer">
        <strong>FEI</strong>
        <em>Florida Education Institute</em>
      </span>
      <p>{f.tagline}</p>
      <div class="footer__social">
        <a href="https://www.facebook.com/FEIMiami" target="_blank" rel="noopener" aria-label="FEI on Facebook"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13.5 21v-8h2.7l.4-3.1h-3.1V7.9c0-.9.25-1.5 1.55-1.5H17V3.6c-.29-.04-1.28-.13-2.43-.13-2.4 0-4.07 1.47-4.07 4.17v2.33H7.7V13h2.8v8z"/></svg></a>
        <a href="https://www.instagram.com/feimiami/" target="_blank" rel="noopener" aria-label="FEI on Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="3.6"/><circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none"/></svg></a>
        <a href="https://x.com/FEIMiami" target="_blank" rel="noopener" aria-label="FEI on X"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.5 3h3l-6.55 7.48L21.8 21h-5.98l-4.3-5.62L6.6 21H3.6l7-8.02L2.5 3h6.13l3.88 5.13z"/></svg></a>
        <a href="mailto:admissions@fei.edu" aria-label="Email FEI admissions"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg></a>
      </div>
    </div>

    <nav class="footer__col" aria-label={f.institute}>
      <h4>{f.institute}</h4>
      <a href={href('/about', lang)}>{f.aboutFei}</a>
      <a href={href('/admissions', lang)}>{f.admissions}</a>
      <a href={href('/financial-aid', lang)}>{f.financialAid}</a>
      <a href={href('/support', lang)}>{f.supportServices}</a>
      <a href={href('/employers', lang)}>{f.forEmployers}</a>
      <a href={href('/blog', lang)}>{f.blog}</a>
      <a href="https://starnet.neolms.com/" target="_blank" rel="noopener">{f.studentPortal}</a>
    </nav>

    <div class="footer__col footer__contact">
      <h4>{f.visit}</h4>
      <p>5818 SW 8th Street<br/>Miami, FL 33144</p>
      <a href="tel:3054441515" class="footer__phone">305-444-1515</a>
      <a href={href('/apply', lang)} class="btn btn--coral" data-apply>{f.apply}</a>
    </div>
  </div>

  <div class="footer__bar">
    <p>© <span>{year}</span> Florida Education Institute. {f.rights}</p>
    <p class="footer__legal">
      <a href={href('/legal/privacy', lang)}>{f.privacy}</a> ·
      <a href={href('/legal/terms', lang)}>{f.terms}</a> ·
      <a href={href('/consumer-information', lang)}>{f.consumerInfo}</a>
    </p>
  </div>
</footer>
