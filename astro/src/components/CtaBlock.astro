---
// Shared site-wide call-to-action block (English). Same content on every page
// that needs a closing CTA — import and drop in <CtaBlock /> (no props).
// The Spanish pages use their own localized CTA.
---
<section class="cta" id="apply">
  <div class="cta__glow" aria-hidden="true"></div>
  <div class="cta__inner">
    <p class="kicker kicker--light">Chase your dreams!</p>
    <h2 class="cta__title">Your new<br/>career awaits!</h2>
    <p class="cta__lede">Contact us today to discuss programs, start dates, and financial aid.</p>
    <div class="cta__actions">
      <a href="tel:3054441515" class="btn btn--coral btn--lg">Call 305-444-1515</a>
      <a href="/apply" class="btn btn--outline btn--lg btn--outline-light">Schedule a call</a>
    </div>
  </div>
</section>
