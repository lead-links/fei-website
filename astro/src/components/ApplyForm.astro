---
import { PROGRAMS } from '../data/programs';
import { t } from '../i18n/ui';
import { href, PROGRAM_TITLE_ES, type Lang } from '../i18n/routes';

// Single source of truth for the lead-capture form, shared by the modal overlay
// (prefix "am") and the /apply page (prefix "af"). All element ids are prefixed
// so both instances can coexist on the same page without id collisions.
// Behavior (validation, phone, UTM restore, program context, submit) lives in
// site.js -> initApplyForm(), keyed by the same prefix.
interface Props {
  prefix: string;
  formId: string;
  submitLabel?: string;
  lang?: Lang;
  stage?: string; // '2-step complete' flow marks the form data-stage="full" (see site.js)
  phoneCta?: boolean; // show the "prefer to talk?" divider + phone button (default true; off on /apply)
}
const { prefix: p, formId, submitLabel, lang = 'en', stage, phoneCta = true } = Astro.props;
const s = t(lang).form;
const legal = t(lang).footer;
const send = submitLabel ?? s.send;
const progTitle = (slug: string, en: string) => (lang === 'es' ? PROGRAM_TITLE_ES[slug] : en);
---
<form
  class="form"
  id={formId}
  novalidate
  data-stage={stage}
  data-msg-required={s.required}
  data-msg-invalid-email={s.invalidEmail}
  data-msg-invalid-phone={s.invalidPhone}
  data-msg-invalid-zip={s.invalidZip}
  data-msg-select-program={s.selectProgramError}
  data-msg-error-summary={s.errorSummary}
>
  <div class="form-summary" id={`${p}-summary`} role="alert" tabindex="-1" hidden></div>

  <div class="field">
    <label for={`${p}-first`}>{s.first}</label>
    <input type="text" id={`${p}-first`} name="firstName" autocomplete="given-name" required aria-describedby={`${p}-first-error`} />
    <p class="field-error" id={`${p}-first-error`} hidden></p>
  </div>
  <div class="field">
    <label for={`${p}-last`}>{s.last}</label>
    <input type="text" id={`${p}-last`} name="lastName" autocomplete="family-name" required aria-describedby={`${p}-last-error`} />
    <p class="field-error" id={`${p}-last-error`} hidden></p>
  </div>
  <div class="field">
    <label for={`${p}-email`}>{s.email}</label>
    <input type="email" id={`${p}-email`} name="email" autocomplete="email" required aria-describedby={`${p}-email-error`} />
    <p class="field-error" id={`${p}-email-error`} hidden></p>
  </div>
  <div class="field">
    <label for={`${p}-phone`}>{s.phone}</label>
    <input type="tel" id={`${p}-phone`} name="phone" autocomplete="tel" aria-describedby={`${p}-phone-error`} />
    <p class="field-error" id={`${p}-phone-error`} hidden></p>
  </div>
  <div class="field field--full">
    <label for={`${p}-zip`}>{s.zip}</label>
    <input type="text" id={`${p}-zip`} name="zip" autocomplete="postal-code" inputmode="numeric" maxlength="10" required aria-describedby={`${p}-zip-error`} />
    <p class="field-error" id={`${p}-zip-error`} hidden></p>
  </div>

  <!-- Program dropdown: visible by default (choose), hidden on program pages (pre-filled).
       Option value stays the English program title (stable lead identifier); the
       label is localized. -->
  <div class="field field--full" id={`${p}-program-field`}>
    <label for={`${p}-program`}>{s.program}</label>
    <select id={`${p}-program`} name="program" required aria-describedby={`${p}-program-error`}>
      <option value="" disabled selected>{s.selectProgram}</option>
      {PROGRAMS.map((prog) => (
        <option value={prog.title}>{progTitle(prog.slug, prog.title)}{prog.tag === 'A.A.S.' ? ' (A.A.S.)' : ''}</option>
      ))}
    </select>
    <p class="field-error" id={`${p}-program-error`} hidden></p>
  </div>

  <!-- Program type: always hidden, populated on program pages -->
  <input type="hidden" id={`${p}-program-type`} name="programType" />

  <!-- Attribution: hidden, restored from first touch (localStorage) -->
  <input type="hidden" id={`${p}-utm-source`} name="utm_source" />
  <input type="hidden" id={`${p}-utm-medium`} name="utm_medium" />
  <input type="hidden" id={`${p}-utm-campaign`} name="utm_campaign" />
  <input type="hidden" id={`${p}-utm-content`} name="utm_content" />
  <input type="hidden" id={`${p}-utm-term`} name="utm_term" />
  <input type="hidden" id={`${p}-utm-id`} name="utm_id" />

  <label class="consent">
    <input type="checkbox" id={`${p}-sms-marketing`} name="smsMarketing" />
    <span>{s.smsMarketing}</span>
  </label>
  <label class="consent">
    <input type="checkbox" id={`${p}-sms-transactional`} name="smsTransactional" />
    <span>{s.smsTransactional}</span>
  </label>
  <p class="consent-fine">{s.fine} <a href={href('/legal/terms', lang)}>{legal.terms}</a> {s.and} <a href={href('/legal/privacy', lang)}>{legal.privacy}</a>.</p>

  <button type="submit" class="btn btn--solid modal__submit">{send}
    <svg viewBox="0 0 24 24" width="16" height="16" aria-hidden="true"><path fill="currentColor" d="M5 12h12.2l-4.6-4.6L14 6l7 7-7 7-1.4-1.4 4.6-4.6H5z"/></svg>
  </button>
  <p class="form-error" id={`${p}-error`} role="alert" hidden>{s.error} <a href="tel:3054441515">305-444-1515</a>.</p>
  {phoneCta && (
    <>
      <h3 class="modal__divider">{s.preferToTalk}</h3>
      <a href="tel:3054441515" class="btn btn--outline modal__phone-btn">305-444-1515</a>
    </>
  )}
</form>
