---
import { getCollection } from 'astro:content';

interface Props { activeCat?: string | null }
const { activeCat = null } = Astro.props;

const posts = await getCollection('blog');
const allCats = Array.from(
  new Map(posts.flatMap((p) => p.data.categories).map((c) => [c.slug, c])).values()
).sort((a, b) => a.name.localeCompare(b.name));
---
<div class="blog-bar">
  <div class="blog-bar__inner">
    <div class="blog-bar__cats" role="tablist" aria-label="Categories">
      <a href="/blog" class={`blog-chip ${!activeCat ? 'is-active' : ''}`}>All</a>
      {allCats.map((c) => (
        <a href={`/blog/category/${c.slug}`} class={`blog-chip ${activeCat === c.slug ? 'is-active' : ''}`}>{c.name}</a>
      ))}
    </div>

    <form class="blog-bar__search" action="/blog/search" method="get" role="search">
      <input type="search" id="blogSearch" name="q" placeholder="Search articles…" aria-label="Search articles" />
      <button type="submit" aria-label="Search">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
      </button>
    </form>
  </div>
</div>

<style>
  .blog-bar { background: var(--blue); }
  .blog-bar__inner {
    max-width: var(--wrap); margin: 0 auto; padding: .85rem var(--pad);
    display: flex; flex-wrap: wrap; gap: .8rem 1.2rem; justify-content: space-between; align-items: center;
  }
  .blog-bar__cats { display: flex; flex-wrap: wrap; gap: .5rem; }
  .blog-chip {
    font-family: var(--display); font-size: .82rem; font-weight: 700; letter-spacing: .01em;
    color: rgba(255,255,255,.9); border: 1px solid rgba(255,255,255,.6); padding: .42em 1em;
    transition: background .2s, color .2s, border-color .2s;
  }
  .blog-chip:hover { background: rgba(255,255,255,.14); color: #fff; }
  .blog-chip.is-active { background: #fff; color: var(--blue-600); border-color: #fff; }

  .blog-bar__search { display: flex; flex-shrink: 0; }
  .blog-bar__search input {
    border: 1px solid rgba(255,255,255,.45); background: rgba(255,255,255,.14); color: #fff;
    padding: .5em .9em; font: inherit; font-size: .9rem; min-width: min(280px, 62vw);
  }
  .blog-bar__search input::placeholder { color: rgba(255,255,255,.9); }
  .blog-bar__search input:focus { outline: 2px solid #fff; outline-offset: -1px; background: rgba(255,255,255,.2); }
  .blog-bar__search button {
    border: 0; background: var(--gold); color: var(--navy); padding: 0 .95em; cursor: pointer;
    display: grid; place-items: center;
  }
</style>
